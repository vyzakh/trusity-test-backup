<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Business Summary</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    @page {
      size: A4 portrait;
      margin: 10mm;
    }

    html,
    body {
      width: 100%;
      height: 100%;
      background: #fff;
    }

    body {
      font-family: 'Arial', sans-serif;
      font-size: 14px;
      line-height: 1.6;
      /* ✅ UNIFIED LINE HEIGHT */
      color: #333;
      padding: 0;
    }

    /* ===== MARKDOWN CONTENT STYLING ===== */
    .markdown-content {
      font-size: 14px;
      line-height: 1.6;
      /* ✅ UNIFIED */
      color: #333;
    }

    .markdown-content h1 {
      font-size: 20px;
      font-weight: 700;
      margin-top: 8px;
      margin-bottom: 10px;
      color: #1a1a1a;
      line-height: 1.3;
    }

    .markdown-content h2 {
      font-size: 17px;
      font-weight: 700;
      margin-top: 8px;
      margin-bottom: 10px;
      color: #2d2d2d;
      line-height: 1.3;
    }

    .markdown-content h3 {
      font-size: 15px;
      font-weight: 700;
      margin-top: 6px;
      margin-bottom: 8px;
      color: #333333;
      line-height: 1.3;
    }

    .markdown-content h4 {
      font-size: 14px;
      font-weight: 600;
      margin-top: 10px;
      margin-bottom: 4px;
      color: #404040;
      line-height: 1.3;
    }

    .markdown-content p {
      margin-bottom: 10px;
      margin-top: 0;
      line-height: 1.6;
      /* ✅ UNIFIED */
      text-align: left;
    }

    .markdown-content ul,
    .markdown-content ol {
      margin-bottom: 14px;
      margin-top: 10px;
      padding-left: 24px;
    }

    .markdown-content ul {
      list-style-type: disc;
    }

    .markdown-content ol {
      list-style-type: decimal;
    }

    .markdown-content li {
      margin-bottom: 6px;
      line-height: 1.6;
      /* ✅ UNIFIED */
    }

    .markdown-content li:last-child {
      margin-bottom: 0;
    }

    .markdown-content ul+h2,
    .markdown-content ul+h3,
    .markdown-content ul+h4,
    .markdown-content ol+h2,
    .markdown-content ol+h3,
    .markdown-content ol+h4 {
      margin-top: 8px;
    }

    .markdown-content strong {
      font-weight: 700;
      color: #1a1a1a;
    }

    .markdown-content em {
      font-style: italic;
    }

    .markdown-content a {
      color: #2563eb;
      text-decoration: underline;
      font-weight: 500;
    }

    .markdown-content code {
      background: #f3f4f6;
      padding: 2px 5px;
      border-radius: 3px;
      font-size: 13px;
      font-family: 'Courier New', monospace;
      color: #e11d48;
    }

    .markdown-content pre {
      margin-bottom: 10px;
      margin-top: 6px;
      overflow-x: auto;
      border-radius: 4px;
      background: #f5f5f5;
      padding: 12px;
      line-height: 1.5;
    }

    .markdown-content pre code {
      background: none;
      padding: 0;
      color: #1a1a1a;
      font-size: 13px;
      font-family: 'Courier New', monospace;
    }

    .markdown-content blockquote {
      margin-bottom: 10px;
      margin-top: 6px;
      border-left: 4px solid #d1d5db;
      padding-left: 12px;
      font-style: italic;
      color: #6b7280;
    }

    .markdown-content hr {
      margin: 12px 0;
      border: none;
      border-top: 1px solid #e5e7eb;
    }

    .markdown-content img {
      margin: 10px 0;
      border-radius: 4px;
      max-width: 100%;
      display: block;
    }

    .markdown-content ul,
    .markdown-content ol,
    .markdown-content li {
      text-align: left !important;
    }

    .markdown-content br {
      display: none;
    }

    /* Container & Header */
    .container {
      max-width: 100%;
      margin: 0;
      padding: 0;
      overflow-wrap: break-word;
    }

    .header {
      background: #f8f9fa;
      padding: 8px;
      border-radius: 0;
      margin-bottom: 6px;
    }

    .header-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 4px;
    }

    .rev-paragraph {
      white-space: pre-line;
      line-height: 1.6;
      /* ✅ UNIFIED */
    }

    .header-label {
      font-size: 12px;
      color: #666;
      text-transform: uppercase;
      margin-bottom: 2px;
    }

    .header-value {
      font-size: 16px;
      font-weight: bold;
      color: #000;
      line-height: 1.3;
    }

    .business-name-field label {
      font-size: 12px;
      color: #666;
      text-transform: uppercase;
      margin-bottom: 2px;
    }

    .business-name-field .value {
      font-size: 18px;
      font-weight: bold;
      color: #000;
      line-height: 1.3;
    }

    .rev-list {
      margin: 4px 0 0 10px;
      padding: 0;
      font-size: 13px;
      line-height: 1.6;
      /* ✅ UNIFIED */
      list-style-position: outside;
    }

    .rev-list li {
      margin: 2.5px 0 2.5px 20px;
      padding: 0;
    }

    /* Sections */
    .section {
      margin-bottom: 6px;
      page-break-inside: auto;
    }

    .section-header {
      background: #E3F2FD;
      padding: 6px 10px;
      border-radius: 3px;
      display: flex;
      align-items: center;
      gap: 6px;
      page-break-after: avoid;
      margin-bottom: 3px;
    }

    .section-header img,
    .section-header svg {
      display: block;
      vertical-align: middle;
      flex-shrink: 0;
    }

    .section-title {
      font-size: 16px;
      font-weight: bold;
      color: #1976D2;
      text-transform: uppercase;
      line-height: 1;
    }

    .section-content {
      font-size: 14px;
      line-height: 1.6;
      /* ✅ UNIFIED - Changed from 1.4 */
      padding: 0 10px;
      text-align: left;
      /* ✅ Changed from justify */
      margin-top: 4px;
      margin-bottom: 0;
    }

    /* Boxes */
    .highlight-box,
    .capex-box,
    .breakeven-chip,
    .investment-box {
      margin: 5px 0;
    }

    .section-header+.capex-box,
    .section-header+.breakeven-chip,
    .section-header+.highlight-box,
    .section-header+.investment-box {
      margin-top: 5px;
    }

    .capex-box,
    .breakeven-chip {
      box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.02) inset;
      border-radius: 6px;
    }

    .highlight-box {
      background: #FEF3C7;
      padding: 6px 10px;
      margin: 4px 0;
      border-radius: 3px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      page-break-inside: avoid;
    }

    .opex-cards {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 6px;
      padding: 3px 0;
    }

    .breakeven-chip {
      background: #F0FDF4;
      border: 1px solid #DCFCE7;
      border-radius: 6px;
      padding: 5px 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }

    .breakeven-label {
      color: #14532D;
      font-size: 13px;
      font-weight: 600;
    }

    .breakeven-value {
      color: #166534;
      font-size: 15px;
      font-weight: 700;
      text-align: right;
    }

    .opex-card {
      background: #F3F4F6;
      border: 1px solid #E5E7EB;
      border-radius: 8px;
      padding: 5px 8px;
      text-align: center;
    }

    .opex-card-year {
      font-size: 12px;
      color: #6B7280;
      margin-bottom: 3px;
    }

    .opex-card-amount {
      font-size: 14px;
      font-weight: 700;
      color: #111827;
    }

    .highlight-label {
      font-size: 13px;
      font-weight: 600;
      color: #78350F;
    }

    .highlight-value {
      font-size: 18px;
      font-weight: bold;
      color: #78350F;
    }

    .capex-box,
    .breakeven-box,
    .investment-box {
      padding: 6px 10px;
      margin: 4px 0;
      border-radius: 3px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      page-break-inside: avoid;
    }

    .capex-box {
      background: #FFF1F1;
      border: 1px solid #FFE0E0;
      color: #C62828;
    }

    .capex-value {
      color: #C62828;
    }

    .capex-label,
    .breakeven-label {
      font-size: 13px;
      font-weight: 600;
    }

    .capex-label {
      color: #C62828;
    }

    .capex-value,
    .breakeven-value {
      font-size: 18px;
      font-weight: bold;
    }

    .investment-box {
      border: 1px solid #C6F6D5;
      background: #F0FFF4;
    }

    .investment-text {
      font-size: 14px;
      line-height: 1.6;
      /* ✅ UNIFIED */
    }

    .opex-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 6px;
      padding: 4px 0;
    }

    .opex-year {
      font-size: 13px;
      color: #666;
    }

    .opex-amount {
      font-size: 18px;
      font-weight: bold;
      color: #000;
    }

    /* Print adjustments */
    @media print {

      .markdown-content,
      .section {
        page-break-inside: auto;
      }

      .markdown-content h1,
      .markdown-content h2,
      .markdown-content h3,
      .markdown-content h4,
      .section-header {
        page-break-after: avoid;
      }

      .markdown-content ul,
      .markdown-content ol,
      .markdown-content blockquote,
      .markdown-content pre,
      .highlight-box,
      .capex-box,
      .breakeven-box,
      .investment-box,
      .opex-cards {
        page-break-inside: avoid;
      }

      .section-content {
        orphans: 3;
        widows: 3;
      }

      body {
        line-height: 1.6;
        /* ✅ UNIFIED */
      }
    }
  </style>

</head>

<body>
  <div class="container">
    <!-- Header Section -->
    <div class="header">
      <div class="header-grid">
        <div class="header-item">
          <div class="header-label">Full Name</div>
          <div class="header-value">{{studentName}}</div>
        </div>
        <div class="header-item">
          <div class="header-label">Grade</div>
          <div class="header-value">{{grade}}</div>
        </div>
        <div class="header-item">
          <div class="header-label">Section</div>
          <div class="header-value">{{section}}</div>
        </div>
      </div>
      <div class="business-name-field">
        <label>Business Name</label>
        <div class="value">{{businessName}}</div>
      </div>
    </div>

    <!-- IDEA Section -->
    {{#if idea}}
