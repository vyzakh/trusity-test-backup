              </linearGradient>
            </defs>
          </svg>
          <p style='margin: 0; font-size: 14px; font-weight: 600; color: #101828'>Class Overall Feedback</p>
        </div>

        {{#if feedback}}
          <p style='margin: 0; font-size: 12px; color: #6b7280'>{{feedback}}</p>
        {{else}}
          <div style='display: flex; align-items: center; justify-content: center; min-height: 160px; font-size: 12px;'>
