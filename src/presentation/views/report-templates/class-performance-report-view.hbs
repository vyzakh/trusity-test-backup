<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Document</title>
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link href='https://fonts.googleapis.com/css2?family=Headland+One&family=Inter:opsz,wght@14..32,100..900&display=swap' rel='stylesheet' />
    <script src='https://cdn.jsdelivr.net/npm/apexcharts'></script>

    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      @page {
        margin: 64px 24px;
      }

      body {
        font-family: 'Inter', sans-serif;
        font-style: normal;
        font-weight: 400;
      }

      th,
      td {
        word-wrap: break-word;
        overflow-wrap: break-word;
        word-break: break-word;
      }
      tbody tr:last-child {
        border-bottom: none !important;
      }

      .markdown-content {
        font-size: 12px;
      }
      .markdown-content * {
        all: revert !important;
        font-size: inherit !important;
      }
    </style>

  </head>
  <body>

    {{! header }}
    <header style='break-inside: avoid; margin-bottom: 32px;'>
      <div style='display: flex; align-items: flex-end;'>
        <div style='flex-shrink: 0; width:fit-content;'>
          <img src='{{assetBaseUrl}}/report/trusity.svg' alt='Trusity' />
        </div>
        <h2 style='flex-grow: 1; text-align: center;'>Class Performance Report</h2>
        <div style='flex-shrink: 0; width:fit-content'>
          <img src='{{assetBaseUrl}}/report/trueprenurs.svg' alt='trueprenurs.ai' />
        </div>
      </div>
    </header>

    {{! class info table }}
    <table style='border: 1px solid #e9e9e9; width: 100%; border-collapse: collapse; table-layout: fixed; break-inside: avoid; margin-bottom: 32px;'>
      <thead>
        <tr style='color: #FFFFFF; font-weight: bold; font-size: 12px; background: linear-gradient(90deg, #f59e0b, #ec6b3b, #d34f5b, #b33a7d, #8b3fae);'>
          <th style='padding: 8px 16px; text-align: left; width: 40%'>School</th>
          <th style='padding: 8px 16px; text-align: center; width: 10%'>Grade</th>
          <th style='padding: 8px 16px; text-align: center; width: 10%'>Class</th>
          <th style='padding: 8px 16px; text-align: center; width: 25%'>Business Status</th>
        </tr>
      </thead>
      <tbody>
        <tr style='font-size: 14px; font-weight: 500; color: #000000;'>
          <td style='border: 1px solid #e9e9e9; padding: 8px 16px; text-align: left;'>{{schoolName}}</td>
          <td style='border: 1px solid #e9e9e9; padding: 8px 16px; text-align: center;'>{{gradeName}}</td>
          <td style='border: 1px solid #e9e9e9; padding: 8px 16px; text-align: center;'>{{sectionName}}</td>
          <td style='border: 1px solid #e9e9e9; padding: 8px 16px; text-align: center;'>{{statusDisplay businessStatus false}}</td>
        </tr>
      </tbody>
    </table>

    {{! overall class performance }}
    <section style='background-color: #F8F8F8; padding:24px 16px; border-radius:16px; break-inside: avoid; margin-bottom: 32px;'>
      <div style='display: flex; flex-direction: column; gap: 16px;'>
        <p style='display: inline-flex; gap: 8px; font-weight: 500; align-items: center; color:#667085; font-size: 14px;'><span>Overall Class Score (OCS)</span><span
            style='color: {{fillColor overallScore}}'
          >{{toFixed2 overallScore}}%</span></p>
        <div style='border: 1px solid #EAECF0; border-radius: 12px; overflow: hidden;'>
          <table style='width: 100%; border-collapse: collapse; table-layout: fixed;'>
            <thead style='background: #FFFFFF; color: #667085; font-weight: 500; font-size: 12px;'>
              <tr style='border-bottom: 1px solid #EAECF0;'>
                <th style='padding: 10px 8px; text-align: left; border:none; width: 70%'>Score Category</th>
                <th style='padding: 10px 8px; text-align: center; border:none; width: 30%'>Score</th>
              </tr>
            </thead>
            <tbody style='background: #FFFFFF; font-size: 14px; font-weight: 500;'>
              <tr style='border-bottom: 1px solid #EAECF0;'>
                <td style='padding: 10px 8px; font-weight: 500; border:none; text-align: left'>Class Innovation Score (CIS)</td>
                <td style='padding: 10px 8px; font-weight: 500; border:none; color: {{fillColor cis}}; text-align: center;'>{{toFixed2 cis}}%</td>
              </tr>
              <tr style='border-bottom: 1px solid #EAECF0;'>
                <td style='padding: 10px 8px; font-weight: 500; border:none; text-align: left'>Class Entrepreneurship Score (CES)</td>
                <td style='padding: 10px 8px; font-weight: 500; border:none; color: {{fillColor ces}}; text-align: center;'>{{toFixed2 ces}}%</td>
              </tr>
              <tr>
                <td style='padding:10px 8px; font-weight: 500; border:none; text-align: left'>Class Communication Score (CCS)</td>
                <td style='padding:10px 8px; font-weight: 500; border:none; color: {{fillColor ccs}}; text-align: center;'>{{toFixed2 ccs}}%</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {{! Student Performance }}
    <section style='break-inside: avoid; margin-bottom: 32px;'>
      <div style='border: 1px solid #EAECF0; border-radius: 12px; overflow: hidden;'>
        <table style='width: 100%; border-collapse: collapse; table-layout: fixed;'>
          <thead style='background: #FFFFFF; color: #667085; font-weight: 500; font-size: 12px;'>
            <tr style='border-bottom: 1px solid #EAECF0;'>
              <th style='padding: 10px 2.5px; text-align: left; border:none; width: 18%'>Student Name</th>
              <th style='padding: 10px 2.5px; text-align: center; border:none; width: 12%'>Top<br />Score</th>
              <th style='padding: 10px 2.5px; text-align: left; border:none; width: 25%'>Business Idea Name</th>
              <th style='padding: 10px 2.5px; text-align: center; border:none; width: 10%'>No. of<br />Completed<br />ideas</th>
              <th style='padding: 10px 2.5px; text-align: center; border:none; width: 9%'>I</th>
              <th style='padding: 10px 2.5px; text-align: center; border:none; width: 9%'>E</th>
              <th style='padding: 10px 2.5px; text-align: center; border:none; width: 9%'>C</th>
              <th style='padding: 10px 2.5px; text-align: center; border:none; width: 10%'>ATS</th>
              <th style='padding: 10px 2.5px; text-align: center; border:none; width: 12%'>Status</th>
            </tr>
          </thead>
          <tbody style='background: #FFFFFF; font-size: 12px;'>
            {{#each studentReports}}
              <tr style='border-bottom: 1px solid #EAECF0; color: #101828'>
                <td style='padding: 10px 2.5px; border:none; text-align: left'>{{studentName}}</td>
                <td style='padding: 10px 2.5px; border:none; color: {{fillColor topScore}}; text-align: center;'>{{toFixed2 topScore}}%</td>
                <td style='padding: 10px 2.5px; border:none; text-align: left;'>{{businessName}}</td>
                <td style='padding: 10px 2.5px; border:none; text-align: center;'>{{completedIdeasCount}}</td>
                <td style='padding: 10px 2.5px; border:none; text-align: center;'>{{toFixed2 avgInnovationScore}}%</td>
                <td style='padding: 10px 2.5px; border:none; text-align: center;'>{{toFixed2 avgEntrepreneurshipScore}}%</td>
                <td style='padding: 10px 2.5px; border:none; text-align: center;'>{{toFixed2 avgCommunicationScore}}%</td>
                <td style='padding: 10px 2.5px; border:none; text-align: center;'>{{toFixed2 ats.totalAvgScore}}%</td>
                <td style='padding: 10px 2.5px; border:none; text-align: center;'>{{{statusDisplay businessStatus true}}}</td>
              </tr>
            {{else}}
              <tr>
                <td colspan="9" style="padding: 16px; text-align: center; color: #667085; font-style: italic;">
                  No student reports available.
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </section>

    {{! AI Feedback }}
    <section style='background: #f9fafb; border-radius: 18px; padding: 18px 22px; break-inside: avoid; margin-bottom: 32px;'>
      <div style='background: #ffffff; border-radius: 12px; padding: 14px 16px; border: 1px solid #e5e7eb'>
        <div style='display: flex; align-items: center; gap: 8px; margin-bottom: 8px'>
