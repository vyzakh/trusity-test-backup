    {{! Chart }}
    <section style='display: flex; align-items: center; gap: 12px; break-inside: avoid; margin-bottom: 32px;'>
      <div style='flex-shrink: 0; display: flex; flex-direction: column; gap: 6px;'>
        <p style='font-size: 12px; color: #667085; font-weight: 500;'>Overall Score</p>
        <p style='font-size: 22px; font-weight: 700; color: {{fillColor overallScore}}'>{{toFixed2 overallScore}}%</p>
      </div>
      <div id='performanceChart' style='flex:1; width: 100%; height: 300px;'></div>
    </section>

    <script>
      document.addEventListener("DOMContentLoaded", function () { const options = { chart: { zoom: { enabled: false }, toolbar: { show: false }, height: 300, animations: { enabled:
      false }, type: 'area', fontFamily: 'Headland One, serif' }, series: [ { name: 'Score', data: [
      {{toFixed2 performanceProgression.problemStatement}},
      {{toFixed2 performanceProgression.marketResearch}},
      {{toFixed2 performanceProgression.marketFit}},
      {{toFixed2 performanceProgression.prototype}},
      {{toFixed2 performanceProgression.businessModel}},
      {{toFixed2 performanceProgression.financialPlanning}},
      {{toFixed2 performanceProgression.marketing}},
      {{toFixed2 performanceProgression.pitchFeedback}}
      ] } ], title: {text:"Overall Class Performance", offsetX:8, style: { fontSize: '18px', fontFamily:"Inter, sans-serif", fontStyle: "normal", color: '#101828', fontWeight: 500
      } }, dataLabels: { enabled: true, formatter: val => val + '%' }, xaxis: { categories: ['I1', 'I2', 'I3', 'I4', 'E1', 'E2', 'E3', 'C1'], tickPlacement: 'between', axisBorder:
      { show: true, color: '#e0e0e0' }, axisTicks: { show: true, color: '#e0e0e0' }, labels: { style: { fontFamily: 'Headland One, serif' } }, tooltip: { enabled: false } }, yaxis:
      { min: 0, max: 100, tickAmount: 5, labels: { formatter: val => val.toFixed(0) } }, grid: { show: true, borderColor: '#a1a1a1ff', strokeDashArray: 3, xaxis: { lines: { show:
      true } }, yaxis: { lines: { show: true } } }, stroke: { width: 2, colors: ['#F59E3D'], curve: 'straight' }, tooltip: { style: { fontFamily: 'Headland One, serif' } },
      annotations: { yaxis: [ { y: 90, borderColor: '#FF0000', strokeDashArray: 3 } ] }, markers: { size: 5, colors: ['#F59E3D'], hover: { size: 8 }, strokeColors: ['#7086FD20'],
      strokeWidth: 15 }, fill: { type: 'gradient', colors: ['#F59E3D'], gradient: { shadeIntensity: 0, opacityFrom: 0.5, opacityTo: 0.1, stops: [0, 100] } } }; const chart = new
      ApexCharts( document.querySelector("#performanceChart"), options ); chart.render().then(() => { window.__CHART_READY__ = true; }); });
    </script>
