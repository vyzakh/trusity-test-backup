{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "@app/auth": "<rootDir>/../libs/auth/src",
    "@app/auth/(.*)": "<rootDir>/../libs/auth/src/$1",
    "@app/aws": "<rootDir>/../libs/aws/src",
    "@app/aws/(.*)": "<rootDir>/../libs/aws/src/$1",
    "@app/datbase": "<rootDir>/../libs/datbase/src",
    "@app/datbase/(.*)": "<rootDir>/../libs/datbase/src/$1",
    "@app/trusity": "<rootDir>/../libs/trusity/src",
    "@app/trusity/(.*)": "<rootDir>/../libs/trusity/src/$1",
    "@trusity/trusity": "<rootDir>/../libs/trusity/src",
    "@trusity/trusity/(.*)": "<rootDir>/../libs/trusity/src/$1"
  }
}